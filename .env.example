APP_NAME=Laravel
APP_ENV=local
APP_KEY=
# PRODUCTION: Set APP_DEBUG=false to hide stack traces and sensitive info
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=hyperlit

# Application database user (restricted, RLS enforced)
DB_USERNAME=hyperlit_app
DB_PASSWORD=your_app_password

# Admin database user (superuser, for migrations only)
# Falls back to DB_USERNAME/DB_PASSWORD if not set
DB_ADMIN_USERNAME=hyperlit_admin
DB_ADMIN_PASSWORD=your_admin_password

SESSION_DRIVER=rls-database
SESSION_LIFETIME=120
# PRODUCTION: Set SESSION_ENCRYPT=true to encrypt session data
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

## Local dev: install Mailpit (`brew install mailpit`) then run `mailpit`.
## Web UI at http://localhost:8025 — all outbound mail is captured there.
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@hyperlit.com"
MAIL_FROM_NAME="Hyperlit"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

LLM_BASE_URL=https://api.fireworks.ai/inference/v1
LLM_API_KEY=

MISTRAL_OCR_API_KEY=

BRAVE_SEARCH_API_KEY=

SEMANTIC_SCHOLAR_API_KEY=

VITE_APP_NAME="${APP_NAME}"
