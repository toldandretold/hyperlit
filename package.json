{
  "private": true,
  "type": "module",
  "scripts": {
    "php": "php artisan serve --host=127.0.0.1 --port=8000",
    "php:network": "php artisan serve --host=0.0.0.0 --port=8000",
    "queue": "php artisan work",
    "queue:import": "php artisan queue:work --queue=default --timeout=1800",
    "queue:citation": "php artisan queue:work --queue=citation-pipeline --timeout=7200",
    "queue:vibe": "php artisan queue:work --queue=vibe --timeout=1800",
    "queue:audio": "php artisan queue:work --queue=audio --timeout=3600",
    "queue:embeddings": "php artisan queue:work --queue=embeddings --timeout=300",
    "queue:search": "php artisan queue:work --queue=search-supplement --sleep=1 --timeout=120",
    "dev": "vite",
    "mail": "lsof -i :1025 -P -n -sTCP:LISTEN >/dev/null 2>&1 && echo 'Mailpit already running, skipping' && tail -f /dev/null || mailpit",
    "dev:all": "node show-ip.js && concurrently -r -n PHP,IMP1,IMP2,CITE,VIBE,AUD,EMBED,SRCH,DEV,MAIL -c \"cyan,magenta,magenta,red,blue,blue,gray,white,green,yellow\" --kill-others-on-fail --restart-tries 3 --restart-after 1000 \"npm:php\" \"npm:queue:import\" \"npm:queue:import\" \"npm:queue:citation\" \"npm:queue:vibe\" \"npm:queue:audio\" \"npm:queue:embeddings\" \"npm:queue:search\" \"npm:dev\" \"npm:mail\"",
    "dev:network": "export VITE_NETWORK=1 && export APP_URL=http://$(node show-ip.js --ip-only):8000 && node show-ip.js --network && concurrently -r -n PHP,IMP1,IMP2,CITE,VIBE,AUD,EMBED,SRCH,DEV,MAIL -c \"cyan,magenta,magenta,red,blue,blue,gray,white,green,yellow\" --kill-others-on-fail --restart-tries 3 --restart-after 1000 \"npm:php:network\" \"npm:queue:import\" \"npm:queue:import\" \"npm:queue:citation\" \"npm:queue:vibe\" \"npm:queue:audio\" \"npm:queue:embeddings\" \"npm:queue:search\" \"npm:dev\" \"npm:mail\"",
    "build": "node scripts/prune-old-build-assets.mjs && vite build && node scripts/bundle-paste-engine.mjs",
    "measure:bundle": "vite build && node scripts/measure-eager-bundle.mjs",
    "gate:bundle": "BUNDLE_GATE=1 vite build && node scripts/check-lazy-chunks.mjs",
    "typecheck": "tsc --noEmit",
    "viz:idb": "php visualisation/php/collect.php && WRITE_FLOWVIZ=1 vitest run tests/javascript/visualisation/flowViz.generate.test.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:tdz": "vite build && node tests/build/tdzProbe.mjs",
    "verify": "bash scripts/verify.sh",
    "test:e2e": "npx playwright test --config tests/e2e/playwright.config.js",
    "test:e2e:pages": "E2E_READING_MODE=paginated npx playwright test --config tests/e2e/playwright.config.js",
    "test:e2e:headed": "npx playwright test --config tests/e2e/playwright.config.js --headed",
    "test:a11y": "npx playwright test --config tests/e2e/playwright.config.js specs/a11y; node tests/e2e/scripts/merge-a11y-report.mjs",
    "build:paste-engine": "node scripts/bundle-paste-engine.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@vitest/ui": "^4.0.5",
    "alpinejs": "^3.4.2",
    "autoprefixer": "^10.4.2",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.0.10",
    "jsdom": "^27.1.0",
    "laravel-vite-plugin": "^1.0",
    "lodash": "^4.17.19",
    "postcss": "^8.4.31",
    "resolve-url-loader": "^5.0.0",
    "sass": "^1.32.11",
    "sass-loader": "^11.0.1",
    "typescript": "^6.0.3",
    "vite": "^6.2.2",
    "vite-plugin-pwa": "^0.21.1",
    "vite-plugin-static-copy": "^2.3.0",
    "vitest": "^4.0.5"
  },
  "dependencies": {
    "@types/three": "^0.185.1",
    "dompurify": "^3.2.6",
    "katex": "^0.16.38",
    "marked": "^15.0.12",
    "patchright": "^1.61.1",
    "playwright": "^1.60.0",
    "three": "^0.185.1"
  }
}
