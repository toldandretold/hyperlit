/.phpunit.cache
/node_modules
/public/build
/public/hot
/public/storage
/storage/*.key
/vendor
.env
.env.backup
.env.production
.env.testing
.phpactor.json
.phpunit.result.cache
Homestead.json
Homestead.yaml
auth.json
npm-debug.log
yarn-error.log
CLAUDE.md
/.fleet
/.idea
/.vscode
/resources/markdown/*
!/resources/markdown/.gitkeep
ignore/
dump.rdb
.DS_Store
*.DS_Store

# Large binary files
*.pdf
*.epub

# …but allow committed import-test fixtures (small, regenerable via _generate_synthetic.py)
!/tests/conversion/import-samples/**/*.pdf
!/tests/conversion/import-samples/**/*.epub
# …except the 60 MB oversized blob — regenerate locally
/tests/conversion/import-samples/bad/oversized.pdf
# …and the native-OCR fixture's source PDF (small, regenerable via its generate_pdf.swift)
!/tests/conversion/fixtures/pdf/**/source.pdf

# hyperlit-ocr CLI build output (build with macOShyperlit/build-cli.sh)
/macOShyperlit/bin/

# Font extras (full package not needed)
public/fonts/inter/info/

# Log files
storage/logs/*.log
!storage/logs/.gitignore

# Playwright E2E
tests/e2e/.env.e2e
tests/e2e/fixtures/.auth-state.json
tests/e2e/report/
tests/e2e/test-results/

# Python bytecode cache (auto-generated, never edit)
__pycache__/
*.pyc
# Real-content conversion fixtures kept local-only (proprietary books not for public repo)
tests/conversion/fixtures-local/
# Co-evolution corpus: local problem files + their converted artifacts, runs, post-mortems, cache.
# README.md (the contract) is the only tracked thing under corpus/.
tests/conversion/corpus/*
!tests/conversion/corpus/README.md
tests/conversion/vibe_eval_report.json
tests/conversion/vibe_eval_report.md
# OCR version-comparison harness: drop input PDFs in -in/, generated caches +
# REPORT.md land in -out/ (base64-heavy, real book content). The script itself IS tracked.
tests/conversion/ocr-compare-in/
tests/conversion/ocr-compare-out/
.css-cascade-snapshots/
.css-style-parity/

# Native macOS shell app (macOShyperlit/) is tracked as part of this monorepo,
# but its Xcode build artifacts should never be committed.
macOShyperlit/build/
macOShyperlit/DerivedData/
macOShyperlit/**/xcuserdata/
macOShyperlit/**/*.xcuserstate
